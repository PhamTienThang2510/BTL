<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_order_item_image"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="@string/product_image"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_image_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_order_item_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/poppins_light"
            android:text="@string/order_item_name_placeholder"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            app:layout_constraintStart_toEndOf="@id/iv_order_item_image"
            app:layout_constraintTop_toTopOf="@id/iv_order_item_image"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_variant_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/sf_pro_display"
            android:text="@string/order_variant_placeholder"
            android:textColor="@color/g_gray700"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/iv_order_item_image"
            app:layout_constraintTop_toBottomOf="@id/tv_order_item_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/sf_pro_display"
            android:text="@string/order_quantity_placeholder"
            android:textColor="@color/g_gray700"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/iv_order_item_image"
            app:layout_constraintTop_toBottomOf="@id/tv_variant_id" />

        <TextView
            android:id="@+id/tv_unit_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/sf_pro_display"
            android:text="@string/order_unit_price_placeholder"
            android:textColor="@color/g_blue"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_variant_id"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_item_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/sf_pro_display"
            android:text="@string/order_item_total_placeholder"
            android:textColor="@color/g_green"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iv_order_item_image"
            app:layout_constraintTop_toBottomOf="@id/tv_quantity" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_review_item"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:text="@string/order_send_review"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:backgroundTint="@color/g_blue"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/tv_item_total"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_created_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/sf_pro_display"
            android:text="@string/order_item_created_placeholder"
            android:textColor="@color/g_gray700"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@id/iv_order_item_image"
            app:layout_constraintTop_toBottomOf="@id/button_review_item" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>


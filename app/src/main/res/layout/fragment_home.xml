<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Search Box (at top) -->
    <TextView
        android:id="@+id/tv_search"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/search_box_background"
        android:fontFamily="@font/poppins_thin"
        android:hint="@string/g_search_now"
        android:paddingStart="@dimen/_12sdp"
        android:singleLine="true"
        android:textColor="@color/g_icon_tint"
        android:textSize="@dimen/_12ssp"
        android:gravity="center_vertical"
        android:drawableEnd="@drawable/ic_search"
        android:padding="10dp"
        android:drawablePadding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Banner Carousel (below search) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_banner"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/banner_rounded_background"
        android:clipToOutline="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_search" />

    <!-- Banner Dots Indicator -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tl_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vp_banner"
        app:tabBackground="@drawable/tab_selector"
        app:tabGravity="center"
        app:tabIconTint="@color/primary_color"
        app:tabIndicatorHeight="0dp" />

    <!-- Main Content Container -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tl_dots">

        <LinearLayout
            android:id="@+id/ll_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Best Deal Title -->
            <TextView
                android:id="@+id/tv_best_deal_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/best_deals"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/g_black"
                android:layout_marginTop="20dp" />

            <!-- Best Deal RecyclerView - Horizontal scroll -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_best_deals"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingEnd="8dp"
                android:scrollbars="none" />

            <!-- Hot-selling Products Title -->
            <TextView
                android:id="@+id/tv_hot_selling_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hot_selling_products"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/g_black"
                android:layout_marginTop="12dp" />

            <!-- Hot-selling Products RecyclerView - Vertical scroll -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_hot_selling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <!-- Best Sellers Title -->
            <TextView
                android:id="@+id/tv_best_sellers_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ Best Sellers"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/g_black"
                android:layout_marginTop="28dp" />

            <!-- Best Sellers RecyclerView - Horizontal scroll -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_best_sellers"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingEnd="8dp"
                android:scrollbars="none"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
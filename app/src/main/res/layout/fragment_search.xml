<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Header / Search Bar -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_back"
        app:tint="#000000"
        app:layout_constraintTop_toTopOf="@id/et_search"
        app:layout_constraintBottom_toBottomOf="@id/et_search"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/et_search"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_search_input"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="8dp"
        android:hint="Tìm kiếm sản phẩm..."
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#000000"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_back"
        app:layout_constraintEnd_toStartOf="@id/iv_filter" />

    <ImageView
        android:id="@+id/iv_filter"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/icon_settings"
        app:tint="#000000"
        app:layout_constraintTop_toTopOf="@id/et_search"
        app:layout_constraintBottom_toBottomOf="@id/et_search"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Last Search Title (Ẩn nếu không có dữ liệu) -->
    <TextView
        android:id="@+id/tv_last_search_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tìm kiếm gần đây"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/et_search"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_clear_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xóa tất cả"
        android:textColor="#673AB7"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/tv_last_search_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_last_search_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Chips Container -->
    <LinearLayout
        android:id="@+id/ll_chips_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_last_search_title">
        
        <LinearLayout
            android:id="@+id/ll_chips_row1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/chip_electronics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_chip"
                android:text="Điện tử     \u00D7"
                android:textColor="#757575"
                android:padding="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_pants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_chip"
                android:text="Quần     \u00D7"
                android:textColor="#757575"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_chips_row2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/chip_three_second"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_chip"
                android:text="Túi xách     \u00D7"
                android:textColor="#757575"
                android:padding="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_long_shirt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_chip"
                android:text="Áo sơ mi     \u00D7"
                android:textColor="#757575"
                android:padding="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Popular Search -->
    <TextView
        android:id="@+id/tv_popular_search_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sản phẩm phổ biến"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/ll_chips_container"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_popular_search"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_popular_search_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        xmlns:tools="http://schemas.android.com/tools"
        tools:listitem="@layout/item_popular_search" />

</androidx.constraintlayout.widget.ConstraintLayout>
